# Feline Research OS — environment variable template
# Copy to .env or export directly in your shell before running.
# Never commit your actual keys.

# Required for Anthropic backend.
# Use only with explicit approval because this project does not enforce an
# Anthropic daily spend cap.
ANTHROPIC_API_KEY=sk-ant-...

# Required for OpenRouter backend
OPENROUTER_API_KEY=sk-or-...

# Required project-side budget acknowledgement for OpenRouter live runs.
# Also set the matching $1/day limit in the OpenRouter dashboard.
OPENROUTER_DAILY_BUDGET_USD=1.00

# Optional: override the default OpenRouter model (openai/gpt-4.1-mini)
# OPENROUTER_MODEL=openai/gpt-4.1-mini

# Streamlit Cloud uses app secrets instead of this .env file. See
# .streamlit/secrets.example.toml for the hosted-deploy format.
